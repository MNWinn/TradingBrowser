# Global
MODE=research
LIVE_TRADING_ENABLED=false

# Backend
DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5433/tradingbrowser
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
KILL_SWITCH=false
AUTO_CREATE_SCHEMA=false

# Simple API role tokens (dev defaults)
ADMIN_API_TOKEN=admin-dev-token
TRADER_API_TOKEN=trader-dev-token
ANALYST_API_TOKEN=analyst-dev-token

# Security secrets
ENCRYPTION_KEY=
ALPACA_WEBHOOK_SECRET=

# Alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex
ALPACA_DATA_WS_IEX=wss://stream.data.alpaca.markets/v2/iex
ALPACA_DATA_WS_SIP=wss://stream.data.alpaca.markets/v2/sip

# MiroFish (optional live integration)
MIROFISH_BASE_URL=
MIROFISH_API_KEY=
MIROFISH_TIMEOUT_SEC=6.0
MIROFISH_SIMULATION_ID=
MIROFISH_FOCUS_TICKERS=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market
NEXT_PUBLIC_ADMIN_API_TOKEN=admin-dev-token
NEXT_PUBLIC_TRADER_API_TOKEN=trader-dev-token
NEXT_PUBLIC_ANALYST_API_TOKEN=analyst-dev-token
